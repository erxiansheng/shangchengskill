# Example .env — copy to project root and fill in values, then add to .gitignore.

# === required ===
JWT_SECRET=                   # 64 hex chars, generate with: python -c "import secrets;print(secrets.token_hex(32))"
INTERNAL_KEY=                 # second 64 hex chars
ADMIN_INIT_USERNAME=root
ADMIN_INIT_PASSWORD=          # >= 12 chars; user is forced to change on first login
KV_NAMESPACE=mall_kv
STORAGE_MODE=kv               # kv | s3

# === optional, S3 fallback (when STORAGE_MODE=s3) ===
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# === optional, third-party login (toggle in /admin/settings) ===
WECHAT_APPID=
WECHAT_SECRET=
APPLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === optional, payments ===
WECHAT_PAY_MCHID=
WECHAT_PAY_KEY=
ALIPAY_APPID=
ALIPAY_PRIVATE_KEY=
