{
  "$schema": "https://pages.edgeone.ai/schemas/edgeone.json",
  "name": "edgeone-mall",
  "buildCommand": "cd frontend && npm install && npm run build",
  "installCommand": "echo skip-root-install",
  "outputDirectory": "frontend/dist",
  "nodeVersion": "20.18.0",

  "cloudFunctions": {
    "python": {
      "maxDuration": 60,
      "includeFiles": ["app/seed/assets/**"]
    }
  },

  "rewrites": [
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/",
      "destination": "/index.html"
    },
    {
      "source": "/skill/*",
      "destination": "/index.html"
    },
    {
      "source": "/product/*",
      "destination": "/index.html"
    },
    {
      "source": "/user/*",
      "destination": "/index.html"
    },
    {
      "source": "/u/*",
      "destination": "/index.html"
    },
    {
      "source": "/upload",
      "destination": "/index.html"
    },
    {
      "source": "/profile",
      "destination": "/index.html"
    },
    {
      "source": "/purchased",
      "destination": "/index.html"
    },
    {
      "source": "/points",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/register",
      "destination": "/index.html"
    },
    {
      "source": "/login/oauth-callback",
      "destination": "/index.html"
    },
    {
      "source": "/favorites",
      "destination": "/index.html"
    },
    {
      "source": "/revenue",
      "destination": "/index.html"
    },
    {
      "source": "/settings",
      "destination": "/index.html"
    },
    {
      "source": "/about",
      "destination": "/index.html"
    },
    {
      "source": "/explore",
      "destination": "/index.html"
    }
  ],

  "headers": [
    {
      "source": "/assets/*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/*",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
