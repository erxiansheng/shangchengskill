.page { padding-bottom: 140rpx; }

/* Back button */
.back-btn {
  padding: 16rpx 24rpx; font-size: 28rpx; color: #8e8e93;
}

/* ========== Header ========== */
.header-glass { margin: 0 24rpx 16rpx; padding: 28rpx; }
.header-tags { display: flex; gap: 12rpx; flex-wrap: wrap; margin-bottom: 16rpx; }
.tag-category {
  font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 8rpx;
  background: rgba(30,224,127,0.12); color: #1ee07f; font-weight: 600;
}
.tag {
  font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 8rpx;
  background: rgba(255,255,255,0.04); color: #8e8e93;
}
.header-title { display: block; font-size: 40rpx; font-weight: 700; color: #e8e6e3; margin-bottom: 12rpx; }
.header-subtitle { display: block; font-size: 28rpx; color: #8e8e93; margin-bottom: 20rpx; line-height: 1.5; }

.meta-row { display: flex; flex-direction: column; gap: 12rpx; }
.author-info { display: flex; align-items: center; gap: 12rpx; }
.author-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; }
.author-avatar-placeholder {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: rgba(255,255,255,0.06); display: flex;
  align-items: center; justify-content: center; font-size: 24rpx;
}
.author-name { font-size: 26rpx; color: #e8e6e3; }
.author-badge { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 16rpx; font-weight: 600; }
.admin-badge { background: rgba(168, 85, 247, 0.15); color: #c084fc; }
.level-badge { background: rgba(30, 224, 127, 0.12); color: #1ee07f; }
.header-stats { display: flex; gap: 16rpx; flex-wrap: wrap; font-size: 22rpx; color: #636366; }

/* ========== Content Tabs ========== */
.content-tabs { margin: 0 24rpx 16rpx; padding: 0; overflow: hidden; }
.tab-scroller { white-space: nowrap; }
.tabs-row {
  display: inline-flex; border-bottom: 1rpx solid rgba(255,255,255,0.06);
  width: 100%; box-sizing: border-box;
}
.tab {
  flex: 1; text-align: center; padding: 24rpx 20rpx; font-size: 26rpx;
  color: #8e8e93; position: relative; white-space: nowrap;
}
.tab.active { color: #1ee07f; font-weight: 600; }
.tab.active::after {
  content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 48rpx; height: 4rpx; background: #1ee07f; border-radius: 2rpx;
}

.tab-content { padding: 24rpx; }

/* Tab: Intro */
.desc-text { font-size: 28rpx; color: #b0b0b4; line-height: 1.7; display: block; white-space: pre-wrap; }

/* Markdown rendered content */
.md-content { font-size: 28rpx; color: #b0b0b4; line-height: 1.7; word-break: break-word; }
.md-content .md-h { color: #e8e6e3; font-weight: 700; margin: 24rpx 0 12rpx; }
.md-content .md-h1 { font-size: 40rpx; }
.md-content .md-h2 { font-size: 36rpx; }
.md-content .md-h3 { font-size: 32rpx; }
.md-content .md-h4 { font-size: 30rpx; }
.md-content .md-p { margin: 12rpx 0; }
.md-content .md-pre {
  background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 12rpx; padding: 20rpx; margin: 16rpx 0; overflow-x: auto;
  font-family: 'Menlo', 'Consolas', monospace; font-size: 24rpx; color: #d4d4d8;
  white-space: pre-wrap; word-break: break-all;
}
.md-content .md-code {
  background: rgba(255,255,255,0.06); padding: 2rpx 10rpx; border-radius: 6rpx;
  font-family: 'Menlo', 'Consolas', monospace; font-size: 24rpx; color: #1ee07f;
}
.md-content .md-quote {
  border-left: 6rpx solid rgba(30,224,127,0.4); padding: 8rpx 20rpx; margin: 12rpx 0;
  background: rgba(30,224,127,0.04); color: #8e8e93;
}
.md-content .md-list { padding-left: 40rpx; margin: 12rpx 0; }
.md-content .md-hr {
  border: none; border-top: 1rpx solid rgba(255,255,255,0.08);
  margin: 24rpx 0;
}
.md-content .md-table {
  width: 100%; border-collapse: collapse; margin: 16rpx 0;
  font-size: 24rpx; overflow-x: auto;
}
.md-content .md-table th, .md-content .md-table td {
  border: 1rpx solid rgba(255,255,255,0.1);
  padding: 12rpx 16rpx; text-align: left;
}
.md-content .md-table th {
  background: rgba(255,255,255,0.05); color: #e8e6e3; font-weight: 600;
}
.md-content .md-table td { color: #b0b0b4; }
.info-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 24rpx; }
.info-item {
  flex: 1; min-width: 200rpx; padding: 16rpx; border-radius: 12rpx;
  background: rgba(255,255,255,0.03);
}
.info-label { display: block; font-size: 22rpx; color: #636366; margin-bottom: 4rpx; }
.info-val { display: block; font-size: 28rpx; font-weight: 600; color: #e8e6e3; }

/* Tab: Install */
.install-title { display: block; font-size: 28rpx; font-weight: 600; color: #e8e6e3; margin-bottom: 12rpx; }
.install-desc { display: block; font-size: 26rpx; color: #8e8e93; line-height: 1.5; margin-bottom: 16rpx; }
.install-cmd {
  padding: 20rpx; text-align: center; font-size: 26rpx; color: #1ee07f;
  border: 1rpx dashed rgba(30,224,127,0.3); margin-bottom: 24rpx;
}
.install-step { margin-top: 24rpx; }
.lock-hint { display: block; text-align: center; padding: 60rpx; font-size: 28rpx; color: #636366; }

/* Tab: Changelog */
.version-item { padding: 16rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.version-item:last-child { border-bottom: none; }
.version-badge { font-size: 28rpx; font-weight: 600; color: #e8e6e3; }
.version-date { font-size: 22rpx; color: #636366; margin-left: 12rpx; }
.version-log { display: block; font-size: 26rpx; color: #8e8e93; margin-top: 8rpx; line-height: 1.5; }

/* Tab: Screenshots */
.screenshots-grid { display: flex; flex-direction: column; gap: 16rpx; }
.screenshot-card { width: 100%; border-radius: 16rpx; }

/* Tab: Reviews */
.review-form { margin-bottom: 24rpx; }
.review-form-title { display: block; font-size: 28rpx; font-weight: 600; color: #e8e6e3; margin-bottom: 16rpx; }
.star-picker { display: flex; gap: 8rpx; margin-bottom: 16rpx; }
.pick-star { font-size: 36rpx; opacity: 0.3; }
.pick-star.active { opacity: 1; }
.review-textarea {
  width: 100%; min-height: 160rpx; font-size: 28rpx; color: #e8e6e3;
  background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 12rpx; padding: 16rpx; box-sizing: border-box;
}
.review-placeholder { color: #636366; }
.review-actions { display: flex; justify-content: flex-end; gap: 20rpx; margin-top: 16rpx; align-items: center; }
.review-cancel { font-size: 26rpx; color: #8e8e93; padding: 12rpx 24rpx; }
.write-review-btn {
  text-align: center; padding: 16rpx; margin-bottom: 20rpx; border-radius: 12rpx;
  background: rgba(30,224,127,0.08); color: #1ee07f; font-size: 28rpx;
}
.btn-sm { font-size: 24rpx !important; padding: 10rpx 24rpx !important; }

.reviews-list { }
.review-item { padding: 16rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.review-item:last-child { border-bottom: none; }
.review-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.review-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; }
.review-avatar-placeholder {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: rgba(255,255,255,0.06); display: flex;
  align-items: center; justify-content: center; font-size: 24rpx;
}
.review-user { flex: 1; }
.review-name { font-size: 26rpx; color: #e8e6e3; display: block; }
.review-date { font-size: 22rpx; color: #636366; display: block; margin-top: 2rpx; }
.review-stars { font-size: 24rpx; color: #FFD60A; }
.review-text { font-size: 28rpx; color: #b0b0b4; line-height: 1.5; display: block; }
.empty-text { display: block; text-align: center; padding: 40rpx; color: #636366; font-size: 26rpx; }

/* Tab: Files */
.file-tree-container { background: rgba(255,255,255,0.03); border-radius: 12rpx; overflow: hidden; padding: 12rpx 0; }
.file-tree-item { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 24rpx; border-bottom: 1rpx solid rgba(255,255,255,0.04); font-size: 26rpx; color: #b0b0b4; }
.file-tree-item:last-child { border-bottom: none; }
.file-tree-item.is-dir { color: #e8e6e3; font-weight: 500; }
.file-icon { font-size: 28rpx; flex-shrink: 0; }
.file-name { flex: 1; word-break: break-all; }
.file-size { font-size: 22rpx; color: #636366; flex-shrink: 0; }

/* ========== Bottom Action Bar ========== */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(10,10,14,0.95); border-top: 1rpx solid rgba(255,255,255,0.06);
  backdrop-filter: blur(20px);
}
.bottom-fav {
  display: flex; flex-direction: column; align-items: center;
  padding: 0 16rpx; flex-shrink: 0;
}
.fav-icon { font-size: 36rpx; }
.fav-text { font-size: 20rpx; color: #8e8e93; }
.bottom-fav.active .fav-text { color: #FF2D55; }
.bottom-main { flex: 1; display: flex; align-items: center; justify-content: space-between; }
.bottom-price { font-size: 32rpx; font-weight: 700; margin-left: 12rpx; }
.bottom-btn { flex-shrink: 0; }

/* ========== Loading ========== */
.loading-page {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; min-height: 60vh; gap: 20rpx;
}
.loading-spinner {
  width: 48rpx; height: 48rpx; border: 4rpx solid rgba(255,255,255,0.1);
  border-top-color: #1ee07f; border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: #636366; }
.loading-wrap { display: flex; justify-content: center; padding: 40rpx; }
