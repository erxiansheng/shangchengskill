.page { padding-bottom: 140rpx; }

/* ============= Search Section ============= */
.search-section {
  position: sticky; top: 0; z-index: 100;
  padding: 16rpx 24rpx;
  background: rgba(10, 10, 14, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}
.search-bar {
  display: flex; align-items: center; gap: 16rpx;
}
.search-input-wrap {
  flex: 1; display: flex; align-items: center; gap: 16rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 48rpx; padding: 18rpx 28rpx;
  transition: border-color 0.2s;
}
.search-input-wrap:focus-within {
  border-color: rgba(30,224,127,0.4);
}
/* CSS magnifier icon in search bar */
.search-icon-circle {
  position: relative; width: 28rpx; height: 28rpx; flex-shrink: 0;
}
.si-ring {
  width: 18rpx; height: 18rpx; border: 3rpx solid #636366;
  border-radius: 50%; position: absolute; top: 0; left: 0;
}
.si-handle {
  position: absolute; width: 8rpx; height: 3rpx;
  background: #636366; border-radius: 2rpx;
  bottom: 2rpx; right: 0; transform: rotate(45deg);
}
.search-input { flex: 1; font-size: 28rpx; color: #e8e6e3; }
.search-placeholder { color: #48484a; }
.search-clear {
  color: #636366; font-size: 28rpx; padding: 0 8rpx;
  width: 40rpx; height: 40rpx; text-align: center; line-height: 40rpx;
}
/* Filter toggle button */
.filter-toggle {
  width: 72rpx; height: 72rpx; border-radius: 20rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: all 0.2s;
}
.filter-toggle.filter-active {
  background: rgba(30,224,127,0.1);
  border-color: rgba(30,224,127,0.3);
}
.filter-bars {
  display: flex; flex-direction: column; gap: 5rpx; align-items: center;
}
.fb {
  width: 28rpx; height: 3rpx; background: #8e8e93;
  border-radius: 2rpx; transition: background 0.2s;
}
.fb-m { width: 20rpx; }
.fb-s { width: 14rpx; }
.filter-active .fb { background: #1ee07f; }

/* ============= Category Chips ============= */
.cat-scroll {
  white-space: nowrap; padding: 12rpx 24rpx 8rpx;
}
.cat-chip {
  display: inline-block; padding: 12rpx 28rpx; margin-right: 12rpx;
  border-radius: 32rpx; font-size: 24rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  color: #8e8e93; transition: all 0.2s;
}
.cat-chip.active {
  background: rgba(30,224,127,0.12);
  border-color: rgba(30,224,127,0.4);
  color: #1ee07f; font-weight: 600;
}

/* ============= Sort Bar ============= */
.sort-bar {
  display: flex; align-items: center; gap: 8rpx;
  padding: 12rpx 24rpx 16rpx;
}
.sort-item {
  padding: 10rpx 24rpx; border-radius: 24rpx; font-size: 24rpx;
  color: #636366; transition: all 0.2s;
}
.sort-item.active {
  background: rgba(30,224,127,0.1);
  color: #1ee07f; font-weight: 600;
}

/* ============= Filter Drawer ============= */
.filter-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 999;
  background: rgba(0,0,0,0.6); opacity: 0; pointer-events: none;
  transition: opacity 0.3s;
}
.filter-overlay.visible { opacity: 1; pointer-events: auto; }
.filter-drawer {
  position: absolute; top: 0; right: 0; width: 80%; height: 100%;
  background: #121216; padding: 40rpx 32rpx; overflow-y: auto;
  transform: translateX(100%); transition: transform 0.3s ease;
}
.filter-drawer.open { transform: translateX(0); }
.drawer-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 40rpx;
}
.drawer-title { font-size: 36rpx; font-weight: 700; color: #e8e6e3; }
.drawer-close {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: rgba(255,255,255,0.06); display: flex;
  align-items: center; justify-content: center;
  font-size: 28rpx; color: #8e8e93;
}
.filter-group { margin-bottom: 36rpx; }
.filter-label {
  display: block; font-size: 24rpx; font-weight: 600;
  color: #8e8e93; margin-bottom: 16rpx; text-transform: uppercase;
  letter-spacing: 2rpx;
}
.filter-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.filter-opt {
  padding: 14rpx 28rpx; border-radius: 32rpx; font-size: 24rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08); color: #8e8e93;
  transition: all 0.2s;
}
.filter-opt.active {
  background: rgba(30,224,127,0.12);
  border-color: rgba(30,224,127,0.4); color: #1ee07f;
}

/* ============= Skill Cards (2-column grid, compact) ============= */
.skill-grid {
  padding: 0 24rpx;
  display: flex; flex-wrap: wrap; gap: 16rpx;
}
.skill-card {
  width: calc(50% - 10rpx);
  background: rgba(255,255,255,0.03);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 20rpx; overflow: hidden;
  padding: 16rpx;
  box-sizing: border-box;
}
.skill-card:active { transform: scale(0.97); }

.card-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 12rpx;
}
.card-cat-tag {
  font-size: 20rpx; color: #1ee07f; font-weight: 600;
  background: rgba(30,224,127,0.1); padding: 4rpx 14rpx;
  border-radius: 8rpx; max-width: 60%;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.card-price { font-size: 22rpx; font-weight: 700; }
.card-price.free { color: #34C759; }
.card-price.paid { color: #FF9F0A; }

.card-title {
  font-size: 26rpx; font-weight: 700; color: #e8e6e3; display: block;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.card-desc {
  font-size: 20rpx; color: #636366; display: -webkit-box; margin-top: 4rpx;
  overflow: hidden; text-overflow: ellipsis;
  -webkit-box-orient: vertical; -webkit-line-clamp: 4;
  word-break: break-all; line-height: 1.5;
  min-height: 90rpx;
}
.card-bottom {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 14rpx;
}
.card-author-row {
  display: flex; align-items: center; gap: 6rpx;
  min-width: 0; flex: 1;
}
.card-avatar-mini {
  width: 28rpx; height: 28rpx; border-radius: 50%; flex-shrink: 0;
  background: linear-gradient(135deg, #1ee07f, #14b866);
  display: flex; align-items: center; justify-content: center;
  font-size: 14rpx; color: #0a0a0e; font-weight: 700;
}
.card-author {
  font-size: 20rpx; color: #8e8e93;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.card-stats-row {
  display: flex; gap: 8rpx; flex-shrink: 0;
}
.card-stat { font-size: 18rpx; color: #636366; white-space: nowrap; }

/* ============= Loading / Empty / End ============= */
.loading-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx; gap: 16rpx;
}
.loading-spinner {
  width: 48rpx; height: 48rpx;
  border: 4rpx solid rgba(255,255,255,0.06);
  border-top-color: #1ee07f; border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 24rpx; color: #48484a; }

.end-hint {
  display: flex; align-items: center; gap: 16rpx;
  justify-content: center; padding: 40rpx 48rpx;
}
.end-line {
  flex: 1; max-width: 80rpx; height: 1rpx;
  background: rgba(255,255,255,0.06);
}
.end-text { font-size: 22rpx; color: #48484a; }

.empty-hint {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 40rpx; gap: 12rpx;
}
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #8e8e93; }
.empty-sub { font-size: 24rpx; color: #48484a; }
