<view class="page">

  <!-- ========== Hero Section ========== -->
  <view class="hero-section">
    <view class="hero-bg-glow"></view>
    <view class="hero-content">
      <text class="hero-badge">🦞 EdgeOneMall 商品市场</text>
      <view class="hero-title">
        <text class="hero-title-line">让每一只小龙虾</text>
        <text class="hero-title-line hero-title-highlight">都成为大聪明</text>
      </view>
      <text class="hero-desc">发现、分享和交易 AI 编程助手商品包，让你的 AI 更智能</text>
      <view class="hero-platforms">
        <view class="platform-tag" wx:for="{{platforms}}" wx:key="name">
          <text>{{item.icon}} {{item.name}}</text>
        </view>
      </view>
      <view class="hero-actions">
        <view class="btn-primary hero-btn" bindtap="goExplore">浏览商品</view>
        <!-- <view class="btn-ghost hero-btn" bindtap="goPublish">发布商品</view> -->
      </view>
    </view>
  </view>

  <!-- ========== Rankings Section ========== -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">🔥 热门排行</text>
      <text class="section-more" bindtap="goExplore">查看全部 →</text>
    </view>
    <view class="ranking-row">
      <!-- Free ranking -->
      <view class="ranking-panel glass-panel">
        <text class="ranking-label">🆓 免费热榜</text>
        <view class="rank-item {{index < 3 ? 'rank-top' : ''}}" wx:for="{{hotFreeSkills}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <view class="rank-num {{index === 0 ? 'gold' : index === 1 ? 'silver' : index === 2 ? 'bronze' : ''}}">{{index + 1}}</view>
          <view class="rank-info">
            <text class="rank-title">{{item.title}}</text>
            <view class="rank-stats">
              <text class="rank-stat">⭐{{item.avg_rating || '-'}}</text>
              <text class="rank-stat">📥{{item.download_count || 0}}</text>
              <text class="rank-stat">❤️{{item.favorite_count || 0}}</text>
            </view>
          </view>
          <text class="rank-price price-free">免费</text>
        </view>
        <view class="rank-empty" wx:if="{{hotFreeSkills.length === 0}}">
          <text>暂无数据</text>
        </view>
      </view>
      <!-- Paid ranking -->
      <view class="ranking-panel glass-panel">
        <text class="ranking-label">💰 付费热榜</text>
        <view class="rank-item {{index < 3 ? 'rank-top' : ''}}" wx:for="{{hotPaidSkills}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <view class="rank-num {{index === 0 ? 'gold' : index === 1 ? 'silver' : index === 2 ? 'bronze' : ''}}">{{index + 1}}</view>
          <view class="rank-info">
            <text class="rank-title">{{item.title}}</text>
            <view class="rank-stats">
              <text class="rank-stat">⭐{{item.avg_rating || '-'}}</text>
              <text class="rank-stat">📥{{item.download_count || 0}}</text>
              <text class="rank-stat">❤️{{item.favorite_count || 0}}</text>
            </view>
          </view>
          <text class="rank-price price-paid">{{item.price}} 积分</text>
        </view>
        <view class="rank-empty" wx:if="{{hotPaidSkills.length === 0}}">
          <text>暂无数据</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== Tutorial Section ========== -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📖 如何使用</text>
    </view>
    <view class="tutorial-steps">
      <view class="step-card glass-panel">
        <text class="step-num">1</text>
        <text class="step-icon">📋</text>
        <text class="step-name">复制指令</text>
        <text class="step-desc">点击下方复制一键安装指令</text>
      </view>
      <view class="step-card glass-panel">
        <text class="step-num">2</text>
        <text class="step-icon">💻</text>
        <text class="step-name">粘贴给 AI</text>
        <text class="step-desc">打开你的 EdgeOneMall、QClaw 等聊天窗口，粘贴刚才复制的指令</text>
      </view>
      <view class="step-card glass-panel">
        <text class="step-num">3</text>
        <text class="step-icon">🔑</text>
        <text class="step-name">提供密钥</text>
        <text class="step-desc">AI 会向你索要 API 密钥，在「个人设置 → API 密钥管理」中创建并提供给 AI</text>
      </view>
      <view class="step-card glass-panel">
        <text class="step-num">4</text>
        <text class="step-icon">✨</text>
        <text class="step-name">自动安装</text>
        <text class="step-desc">AI 自动浏览市场、购买商品、下载安装包，按 SKILL.md 说明完成安装</text>
      </view>
    </view>
    <view class="tutorial-action">
      <view class="btn-ghost" bindtap="copyInstruction">📋 复制通用安装指令</view>
    </view>
  </view>

  <!-- ========== Categories Section ========== -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📂 商品分类</text>
    </view>
    <scroll-view class="cat-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="cat-list">
        <view class="cat-chip {{activeCategory === '' ? 'active' : ''}}" bindtap="selectCat" data-id="">
          <text>🌐 全部</text>
        </view>
        <view class="cat-chip {{activeCategory === item.id ? 'active' : ''}}"
          wx:for="{{categories}}" wx:key="id" bindtap="selectCat" data-id="{{item.id}}">
          <text>{{item.icon}} {{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ========== Featured Skills Section ========== -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">⭐ 精选商品</text>
      <text class="section-more" bindtap="goExplore">更多 →</text>
    </view>
    <view class="skill-grid">
      <view class="skill-card" wx:for="{{skills}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <view class="card-head">
          <text class="card-cat-tag">{{item.category_name || '未分类'}}</text>
          <text class="card-price {{item.is_free || item.price === 0 ? 'free' : 'paid'}}">
            {{item.is_free || item.price === 0 ? '免费' : item.price + '💰'}}
          </text>
        </view>
        <text class="card-title">{{item.title}}</text>
        <text class="card-desc">{{item.subtitle || item.description || '暂无描述'}}</text>
        <view class="card-bottom">
          <view class="card-author-row">
            <view class="card-avatar-mini">{{item.author_name ? item.author_name[0] : '?'}}</view>
            <text class="card-author">{{item.author_name || '匿名'}}</text>
          </view>
          <view class="card-stats-row">
            <text class="card-stat">⭐{{item.avg_rating || '-'}}</text>
            <text class="card-stat">📥{{item.download_count || 0}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
    </view>
    <view class="empty-hint" wx:if="{{!loading && skills.length === 0}}">
      <text class="empty-icon">🔍</text>
      <text>暂无相关商品</text>
    </view>
  </view>

</view>
