.page { padding-bottom: 140rpx; }

/* ========== Hero Section ========== */
.hero-section {
  position: relative; padding: 80rpx 32rpx 60rpx; text-align: center;
  overflow: hidden;
}
.hero-bg-glow {
  position: absolute; top: -200rpx; left: 50%; width: 600rpx; height: 600rpx;
  transform: translateX(-50%); border-radius: 50%;
  background: radial-gradient(circle, rgba(30,224,127,0.15) 0%, transparent 70%);
  pointer-events: none;
}
.hero-content { position: relative; z-index: 1; }
.hero-badge {
  display: inline-block; padding: 8rpx 24rpx; border-radius: 32rpx;
  background: rgba(30,224,127,0.1); border: 1rpx solid rgba(30,224,127,0.3);
  color: #1ee07f; font-size: 24rpx; margin-bottom: 24rpx;
}
.hero-title { margin-bottom: 20rpx; }
.hero-title-line { display: block; font-size: 48rpx; font-weight: 700; color: #e8e6e3; line-height: 1.3; }
.hero-title-highlight {
  background: linear-gradient(135deg, #1ee07f, #00d4ff);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.hero-desc { font-size: 28rpx; color: #8e8e93; margin-bottom: 32rpx; line-height: 1.6; }
.hero-platforms { display: flex; justify-content: center; gap: 16rpx; flex-wrap: wrap; margin-bottom: 36rpx; }
.platform-tag {
  padding: 8rpx 20rpx; border-radius: 24rpx; font-size: 22rpx;
  background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); color: #b0aead;
}
.hero-actions { display: flex; justify-content: center; gap: 24rpx; }
.hero-btn { padding: 16rpx 48rpx !important; font-size: 28rpx !important; border-radius: 12rpx; }

/* ========== Section Common ========== */
.section { padding: 32rpx 24rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.section-title { font-size: 34rpx; font-weight: 700; color: #e8e6e3; }
.section-more { font-size: 24rpx; color: #1ee07f; }

/* ========== Rankings ========== */
.ranking-row { display: flex; gap: 20rpx; }
.ranking-panel { flex: 1; padding: 24rpx; min-width: 0; }
.ranking-label { display: block; font-size: 26rpx; font-weight: 600; color: #e8e6e3; margin-bottom: 20rpx; }
.rank-item { display: flex; align-items: center; gap: 12rpx; padding: 14rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.rank-item:last-of-type { border-bottom: none; }
.rank-num {
  width: 40rpx; height: 40rpx; border-radius: 50%; font-size: 22rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  background: rgba(255,255,255,0.06); color: #8e8e93;
}
.rank-num.gold { background: rgba(255,215,0,0.15); color: #FFD700; }
.rank-num.silver { background: rgba(192,192,192,0.15); color: #C0C0C0; }
.rank-num.bronze { background: rgba(205,127,50,0.15); color: #CD7F32; }
.rank-info { flex: 1; min-width: 0; }
.rank-title { font-size: 26rpx; color: #e8e6e3; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.rank-stats { display: flex; gap: 12rpx; margin-top: 6rpx; }
.rank-stat { font-size: 20rpx; color: #636366; }
.rank-price { font-size: 22rpx; flex-shrink: 0; }
.price-free { color: #1ee07f; }
.price-paid { color: #FFD700; }
.rank-empty { text-align: center; padding: 40rpx; color: #636366; font-size: 24rpx; }

/* ========== Tutorial ========== */
.tutorial-steps { display: flex; flex-wrap: wrap; gap: 16rpx; }
.step-card {
  flex: 1; min-width: 280rpx; padding: 24rpx; text-align: center; position: relative;
}
.step-num {
  position: absolute; top: 12rpx; left: 16rpx; font-size: 20rpx; font-weight: 700;
  color: rgba(30,224,127,0.4);
}
.step-icon { display: block; font-size: 48rpx; margin-bottom: 12rpx; }
.step-name { display: block; font-size: 26rpx; font-weight: 600; color: #e8e6e3; margin-bottom: 8rpx; }
.step-desc { display: block; font-size: 22rpx; color: #8e8e93; line-height: 1.5; }
.tutorial-action { text-align: center; margin-top: 24rpx; }

/* ========== Categories ========== */
.cat-scroll { white-space: nowrap; margin-bottom: 8rpx; }
.cat-list { display: inline-flex; gap: 16rpx; }
.cat-chip {
  display: inline-block; padding: 14rpx 28rpx; font-size: 26rpx;
  border-radius: 32rpx; background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08); color: #8e8e93;
  white-space: nowrap;
}
.cat-chip.active { background: rgba(30,224,127,0.1); border-color: #1ee07f; color: #1ee07f; }

/* ========== Skill Cards (2-col grid, compact) ========== */
.skill-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.skill-card {
  width: calc(50% - 10rpx);
  background: rgba(255,255,255,0.03);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 20rpx; overflow: hidden;
  padding: 16rpx; box-sizing: border-box;
}
.skill-card:active { transform: scale(0.97); }

.card-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 12rpx;
}
.card-cat-tag {
  font-size: 20rpx; color: #1ee07f; font-weight: 600;
  background: rgba(30,224,127,0.1); padding: 4rpx 14rpx;
  border-radius: 8rpx; max-width: 60%;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.card-price { font-size: 22rpx; font-weight: 700; }
.card-price.free { color: #34C759; }
.card-price.paid { color: #FF9F0A; }

.card-title {
  font-size: 26rpx; font-weight: 700; color: #e8e6e3; display: block;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.card-desc {
  font-size: 20rpx; color: #636366; display: -webkit-box; margin-top: 4rpx;
  overflow: hidden; text-overflow: ellipsis;
  -webkit-box-orient: vertical; -webkit-line-clamp: 4;
  word-break: break-all; line-height: 1.5;
  min-height: 90rpx;
}
.card-bottom {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 14rpx;
}
.card-author-row {
  display: flex; align-items: center; gap: 6rpx;
  min-width: 0; flex: 1;
}
.card-avatar-mini {
  width: 28rpx; height: 28rpx; border-radius: 50%; flex-shrink: 0;
  background: linear-gradient(135deg, #1ee07f, #14b866);
  display: flex; align-items: center; justify-content: center;
  font-size: 14rpx; color: #0a0a0e; font-weight: 700;
}
.card-author {
  font-size: 20rpx; color: #8e8e93;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.card-stats-row { display: flex; gap: 8rpx; flex-shrink: 0; }
.card-stat { font-size: 18rpx; color: #636366; white-space: nowrap; }

/* ========== Loading / Empty ========== */
.loading-wrap { display: flex; justify-content: center; padding: 40rpx; }
.loading-spinner {
  width: 48rpx; height: 48rpx; border: 4rpx solid rgba(255,255,255,0.1);
  border-top-color: #1ee07f; border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.empty-hint { text-align: center; padding: 120rpx 40rpx; color: #636366; font-size: 28rpx; }
.empty-icon { display: block; font-size: 80rpx; margin-bottom: 20rpx; }
