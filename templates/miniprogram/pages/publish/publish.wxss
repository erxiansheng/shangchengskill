.page { padding: 0 0 140rpx; }

/* Login prompt */
.login-prompt {
  margin: 120rpx 32rpx; padding: 60rpx 40rpx; text-align: center;
}
.login-icon { display: block; font-size: 80rpx; margin-bottom: 20rpx; }
.login-title { display: block; font-size: 34rpx; font-weight: 700; color: #e8e6e3; margin-bottom: 12rpx; }
.login-desc { display: block; font-size: 26rpx; color: #8e8e93; margin-bottom: 32rpx; }

/* Page header */
.page-header { padding: 40rpx 32rpx 16rpx; }
.page-title { display: block; font-size: 40rpx; font-weight: 700; color: #e8e6e3; }
.page-subtitle { display: block; font-size: 26rpx; color: #8e8e93; margin-top: 8rpx; line-height: 1.5; }

/* Form card */
.form-card { margin: 16rpx 24rpx; padding: 32rpx; }

.form-group { margin-bottom: 28rpx; }
.form-label { display: block; font-size: 26rpx; font-weight: 600; color: #b0aead; margin-bottom: 12rpx; }
.form-label-row {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 12rpx;
}
.form-label-row .form-label { margin-bottom: 0; }
.preview-toggle {
  font-size: 24rpx; color: #1ee07f; padding: 6rpx 16rpx;
  border-radius: 8rpx; background: rgba(30,224,127,0.08);
}
.md-preview-box {
  min-height: 300rpx; padding: 24rpx; font-size: 28rpx; color: #b0b0b4;
  line-height: 1.7; word-break: break-word;
  background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 12rpx; box-sizing: border-box;
}
.md-preview-box .md-h { color: #e8e6e3; font-weight: 700; margin: 16rpx 0 8rpx; }
.md-preview-box .md-h1 { font-size: 36rpx; }
.md-preview-box .md-h2 { font-size: 32rpx; }
.md-preview-box .md-h3 { font-size: 30rpx; }
.md-preview-box .md-p { margin: 8rpx 0; }
.md-preview-box .md-pre {
  background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 8rpx; padding: 16rpx; margin: 12rpx 0; font-size: 22rpx;
  color: #d4d4d8; white-space: pre-wrap; word-break: break-all;
}
.md-preview-box .md-code {
  background: rgba(255,255,255,0.06); padding: 2rpx 8rpx; border-radius: 4rpx;
  font-size: 24rpx; color: #1ee07f;
}
.md-preview-box .md-quote {
  border-left: 6rpx solid rgba(30,224,127,0.4); padding: 6rpx 16rpx; margin: 8rpx 0;
  background: rgba(30,224,127,0.04); color: #8e8e93;
}
.md-preview-box .md-list { padding-left: 32rpx; margin: 8rpx 0; }
.md-preview-box .md-table {
  width: 100%; border-collapse: collapse; margin: 12rpx 0; font-size: 22rpx;
}
.md-preview-box .md-table th, .md-preview-box .md-table td {
  border: 1rpx solid rgba(255,255,255,0.1); padding: 10rpx 12rpx; text-align: left;
}
.md-preview-box .md-table th {
  background: rgba(255,255,255,0.05); color: #e8e6e3; font-weight: 600;
}
.md-preview-box .md-table td { color: #b0b0b4; }
.required { color: #ff6b6b; }
.form-control {
  width: 100%; padding: 24rpx 24rpx; font-size: 28rpx; color: #e8e6e3;
  background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 12rpx; box-sizing: border-box; min-height: 88rpx;
  line-height: 1.4;
}
.form-control:focus { border-color: #1ee07f; }
.textarea { height: 160rpx; }
.textarea.tall { height: 300rpx; }
.field-hint { font-size: 22rpx; color: #636366; margin-top: 8rpx; }
.field-error { display: block; font-size: 22rpx; color: #ff7b72; margin-top: 8rpx; line-height: 1.5; }
.form-error {
  margin-top: 8rpx; margin-bottom: 16rpx; padding: 20rpx 24rpx;
  border-radius: 12rpx; background: rgba(255,107,107,0.08);
  border: 1rpx solid rgba(255,107,107,0.2); color: #ffb4aa;
  font-size: 24rpx; line-height: 1.6;
}

.form-row { display: flex; gap: 20rpx; }
.form-group.half { flex: 1; }

/* Picker */
.picker-display {
  display: flex; justify-content: space-between; align-items: center;
}
.placeholder-text { color: #636366; }
.picker-arrow { color: #636366; font-size: 22rpx; }

/* Upload box */
.upload-box {
  padding: 40rpx; text-align: center; border-radius: 16rpx;
  background: rgba(255,255,255,0.03); border: 2rpx dashed rgba(255,255,255,0.12);
}
.upload-icon { display: block; font-size: 60rpx; margin-bottom: 12rpx; }
.upload-text { display: block; font-size: 28rpx; color: #e8e6e3; margin-bottom: 8rpx; }
.upload-hint { display: block; font-size: 22rpx; color: #636366; }

/* Screenshots */
.screenshot-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.screenshot-item { position: relative; width: 200rpx; height: 200rpx; border-radius: 12rpx; overflow: hidden; }
.screenshot-img { width: 100%; height: 100%; }
.screenshot-remove {
  position: absolute; top: 4rpx; right: 4rpx; width: 40rpx; height: 40rpx;
  background: rgba(0,0,0,0.7); color: #fff; font-size: 24rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.screenshot-add {
  width: 200rpx; height: 200rpx; border-radius: 12rpx;
  background: rgba(255,255,255,0.03); border: 2rpx dashed rgba(255,255,255,0.12);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.add-icon { font-size: 48rpx; color: #636366; }
.add-text { font-size: 22rpx; color: #636366; margin-top: 4rpx; }

/* Submit */
.submit-btn { margin-top: 16rpx; text-align: center; }
.submit-btn.disabled { opacity: 0.5; pointer-events: none; }
